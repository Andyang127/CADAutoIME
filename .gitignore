# ========================================
# 1. 核心编译输出与临时文件
# ========================================
# 忽略所有项目的 bin 和 obj 目录
[Bb]in/
[Oo]bj/
# 忽略根目录的最终发布构建文件夹
build/
# 忽略项目备忘与本地备份文件夹
Backup/
项目备忘/
项目备忘

# ========================================
# 2. 第三方商业依赖库（法律合规：极度重要）
# ========================================
# 严禁上传 Autodesk AutoCAD 专有 API 库，防止侵权
lib/**/*.dll

# ========================================
# 3. 安装包构建输出 (Inno Setup)
# ========================================
installer/Output/
installer/*.exe

# ========================================
# 4. Visual Studio 本地缓存与个人设置
# ========================================
.vs/
*.user
*.userosscache
*.sln.docstates
*.suo
*.vssscc

# ========================================
# 5. C# / .NET 常见日志与缓存
# ========================================
*.log
*.cache
TempPE/
*.pdb
*.nupkg

# 忽略设计时生成的 WPF 临时文件
*.g.cs
*.g.i.cs
*.baml
*.g.resources