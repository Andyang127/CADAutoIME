<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0-windows</TargetFramework>
		<UseWindowsForms>true</UseWindowsForms>
		<UseWPF>true</UseWPF>
		<GenerateAssemblyInfo>false</GenerateAssemblyInfo>
		<DefineConstants>$(DefineConstants);USE_WPF</DefineConstants>
		<ImplicitUsings>disable</ImplicitUsings>
		<Nullable>disable</Nullable>
		<PlatformTarget>x64</PlatformTarget>
		<OutputPath>..\..\build\Sys25</OutputPath>
		<AppendTargetFrameworkToOutputPath>False</AppendTargetFrameworkToOutputPath>
		<AppendRuntimeIdentifierToOutputPath>False</AppendRuntimeIdentifierToOutputPath>
		<AppendConfigurationToOutputPath>False</AppendConfigurationToOutputPath>
		<GenerateDependencyFile>False</GenerateDependencyFile>
		<BaseOutputPath>..\..\build\Sys25</BaseOutputPath>
		<NoWarn>$(NoWarn);MSB3277</NoWarn>
		<Platforms>AnyCPU;x86</Platforms>
		<AssemblyName >OpenCadIme_R25.0_CAD_2025</AssemblyName>
		<RootNamespace/>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
		<DebugType>none</DebugType>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|x86'">
	  <DebugType>none</DebugType>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
		<DebugType>none</DebugType>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|x86'">
	  <DebugType>none</DebugType>
	</PropertyGroup>

	<ItemGroup>
		<Reference Include="AcCoreMgd">
			<HintPath>..\..\lib\R25.0_CAD_2025\AcCoreMgd.dll</HintPath>
			<Private>False</Private>
			<SpecificVersion>False</SpecificVersion>
		</Reference>
		<Reference Include="AcDbMgd">
			<HintPath>..\..\lib\R25.0_CAD_2025\AcDbMgd.dll</HintPath>
			<Private>False</Private>
			<SpecificVersion>False</SpecificVersion>
		</Reference>
		<Reference Include="AcMgd">
			<HintPath>..\..\lib\R25.0_CAD_2025\AcMgd.dll</HintPath>
			<Private>False</Private>
			<SpecificVersion>False</SpecificVersion>
		</Reference>
	</ItemGroup>

	<Import Project="..\..\OpenCadIme.Core\OpenCadIme.Core.projitems" Label="Shared" />

</Project>