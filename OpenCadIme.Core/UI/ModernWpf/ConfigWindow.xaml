<Window x:Class="OpenCadIme.UI.ModernWpf.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CAD Auto IME 白名单配置"
        Height="720" Width="620"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterOwner"
        MaxHeight="{Binding Source={x:Static SystemParameters.WorkArea}, Path=Height}">

    <!-- ============================================ -->
    <!--  样式资源：关闭按钮 + 暗黑主题滚动条          -->
    <!-- ============================================ -->
    <Window.Resources>

        <!-- 关闭按钮：Windows 11 风格，圆角 + hover 变红 -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="46" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#969696" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
            <Setter Property="Content" Value="&#xE8BB;" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            CornerRadius="0,16,0,0"
                            SnapsToDevicePixels="True">
                            <ContentPresenter x:Name="content"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          TextElement.Foreground="{TemplateBinding Foreground}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E81123" />
                                <Setter TargetName="content" Property="TextElement.Foreground" Value="White" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#C40C1B" />
                                <Setter TargetName="content" Property="TextElement.Foreground" Value="White" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 滚动条 Thumb：暗黑主题 -->
        <Style x:Key="DarkScrollThumb" TargetType="Thumb">
            <Setter Property="Background" Value="#686868" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Border x:Name="thumbBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="3"
                            Margin="2,0" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="thumbBorder" Property="Background" Value="#888888" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 垂直滚动条：暗黑主题 -->
        <Style x:Key="DarkVerticalScrollBar" TargetType="ScrollBar">
            <Setter Property="Width" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineUpCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineDownCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkScrollThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- 水平滚动条：暗黑主题 -->
        <Style x:Key="DarkHorizontalScrollBar" TargetType="ScrollBar">
            <Setter Property="Height" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid Background="Transparent">
                            <Track x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineLeftCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="ScrollBar.LineRightCommand">
                                        <RepeatButton.Template>
                                            <ControlTemplate>
                                                <Border Background="Transparent" />
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource DarkScrollThumb}" />
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollViewer：应用暗黑滚动条 -->
        <Style x:Key="DarkScrollViewer" TargetType="ScrollViewer">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollViewer">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <ScrollContentPresenter Grid.Column="0" Grid.Row="0"
                                                CanContentScroll="{TemplateBinding CanContentScroll}" />
                            <ScrollBar x:Name="PART_VerticalScrollBar"
                                   Grid.Column="1" Grid.Row="0"
                                   Style="{StaticResource DarkVerticalScrollBar}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}" />
                            <ScrollBar x:Name="PART_HorizontalScrollBar"
                                   Grid.Column="0" Grid.Row="1"
                                   Style="{StaticResource DarkHorizontalScrollBar}"
                                   Orientation="Horizontal"
                                   ViewportSize="{TemplateBinding ViewportWidth}"
                                   Maximum="{TemplateBinding ScrollableWidth}"
                                   Value="{TemplateBinding HorizontalOffset}"
                                   Visibility="{TemplateBinding ComputedHorizontalScrollBarVisibility}" />
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Border Background="#1E1E1E"
            CornerRadius="16"
            BorderBrush="#3C3C3C"
            BorderThickness="1"
            MouseLeftButtonDown="Window_MouseLeftButtonDown">
        <Grid Margin="20,15,20,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <!-- 顶部标题栏区域 -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                        <!-- 赋予名字，以便在后台通过 AppConstants 无硬编码引用 -->
                        <TextBlock x:Name="lblTitle" Text="CAD Auto IME 白名单配置" FontSize="20" FontWeight="Bold" Foreground="White" />
                        <TextBlock x:Name="lblVersion" Text="v0.4.0" FontSize="14" FontStyle="Italic" Foreground="#00D2D3" Margin="8,4,0,0" />
                        <!-- 新增：更新提示文字，默认隐藏，由后台 UpdateManager 触发显示 -->
                        <TextBlock x:Name="lblCheckUpdate" Text="[发现新版，点击更新]" FontSize="12" Foreground="#28BE50" Margin="10,6,0,0" Cursor="Hand" Visibility="Collapsed" MouseLeftButtonDown="LblCheckUpdate_MouseLeftButtonDown" />
                    </StackPanel>
                    <TextBlock Text="配置列表中的指令，在启动时会自动切换为中文输入法。" Foreground="#AAAAAA" FontSize="12" />
                </StackPanel>

                <!-- 优化后的关闭按钮：Win11 风格 -->
                <Button Style="{StaticResource CloseButtonStyle}"
                        HorizontalAlignment="Right" VerticalAlignment="Top"
                        Click="BtnClose_Click" />
            </Grid>
            <!-- 搜索框区域 -->
            <Border Grid.Row="1" Background="#2D2D30" BorderBrush="#3C3C3C" BorderThickness="1" Margin="0,0,0,15" Height="40">
                <TextBox x:Name="txtSearch"
                         Background="Transparent" Foreground="White" BorderThickness="0"
                         VerticalAlignment="Center" Padding="10,0" FontSize="14"
                         TextChanged="TxtSearch_TextChanged" />
            </Border>
            <!-- 主体指令列表区域 -->
            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="6*" />
                    <RowDefinition Height="4*" />
                </Grid.RowDefinitions>
                <!-- 自定义指令区 -->
                <Border Grid.Row="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" Margin="0,0,0,10" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="我的扩展指令 (须添加命令全称，而非快捷键)" Foreground="White" Margin="0,0,0,10" />
                        <Grid Grid.Row="1" Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtNewCmd" Grid.Column="0" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="8" KeyDown="TxtNewCmd_KeyDown" />
                            <Button Grid.Column="1" Content="添加" Background="#3200D2D3" Foreground="#00D2D3" BorderThickness="0" Cursor="Hand" Click="BtnAdd_Click" />
                        </Grid>
                        <!-- 优化后的滚动条 -->
                        <ScrollViewer Grid.Row="2"
                                      Style="{StaticResource DarkScrollViewer}"
                                      VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="wpCustom" />
                        </ScrollViewer>
                    </Grid>
                </Border>
                <!-- 核心指令区 -->
                <Border Grid.Row="1" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1" Padding="10">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Grid Grid.Row="0" Margin="0,0,0,10">
                            <TextBlock Text="系统内置指令" Foreground="#AAAAAA" HorizontalAlignment="Left" />
                            <TextBlock Text="⚠ 建议不要删除核心指令" Foreground="#F04747" HorizontalAlignment="Right" />
                        </Grid>
                        <!-- 优化后的滚动条 -->
                        <ScrollViewer Grid.Row="1"
                                      Style="{StaticResource DarkScrollViewer}"
                                      VerticalScrollBarVisibility="Auto">
                            <WrapPanel x:Name="wpCore" />
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
            <!-- 底部控制与保存区域 -->
            <Grid Grid.Row="3" Margin="0,15,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Top">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock Text="接管模式：" Foreground="#969696" VerticalAlignment="Center" FontSize="13" />
                        <RadioButton x:Name="RbProcess" Content="进程控制 (推荐)" Foreground="White" FontSize="13" VerticalAlignment="Center" IsChecked="True" Cursor="Hand" Margin="5,0,15,0" ToolTip="仅在 CAD 窗口激活时切换，切出到微信/浏览器保持原样。适合微信输入法等现代框架。" />
                        <RadioButton x:Name="RbGlobal" Content="全局控制" Foreground="White" FontSize="13" VerticalAlignment="Center" Cursor="Hand" ToolTip="强制接管 Windows 系统全局键盘布局。适合老旧输入法或经常状态错乱的情况。" />
                    </StackPanel>
                    <TextBlock Text="快捷键: 双击命令 或 点击命令后 按 Delete 删除 | Ctrl+Z 撤销" Foreground="#787878" FontSize="12" Margin="0,0,0,4" />
                    <TextBlock x:Name="lblStatus" Text="✅ 状态提示" Foreground="#00D2D3" FontSize="12" Visibility="Collapsed" />
                </StackPanel>
                <StackPanel Grid.Column="1" VerticalAlignment="Top" HorizontalAlignment="Right">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,0,0,12">
                        <Button Content="恢复默认" Width="90" Height="34" Background="#252526" Foreground="White" BorderBrush="#3C3C3C" BorderThickness="1" Cursor="Hand" Margin="0,0,10,0" Click="BtnReset_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                        <Button Content="保存应用" Width="120" Height="34" Background="#00D2D3" Foreground="#141414" FontWeight="Bold" BorderThickness="0" Cursor="Hand" Click="BtnSave_Click">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" FontSize="12">
                    <Hyperlink Foreground="#969696" TextDecorations="None" RequestNavigate="Hyperlink_RequestNavigate" NavigateUri="https://v.douyin.com/fuX41UdMKeE/">
                        <Run Text="@ [浅醉·墨语] | [点击此处反馈]" />
                    </Hyperlink>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>